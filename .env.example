#########################################
# APP RUNTIME
#########################################

NODE_ENV=production
HOST_BIND_IP=127.0.0.1
HOST_PORT=3000
LOCAL_UPLOAD_DIR=./local_uploads
UPLOAD_DIR=/app/uploads

# Use your public hostname once the tunnel is live.
BASE_URL=https://upload.example.com/
ALLOWED_ORIGINS=https://upload.example.com

#########################################
# UI / UPLOAD
#########################################

DUMBDROP_TITLE=File Upload
MAX_FILE_SIZE=1024
AUTO_UPLOAD=true

#########################################
# SECRETS
#########################################

# PIN protection (4-10 digits)
DUMBDROP_PIN=12345678

# Cloudflare Tunnel token from Zero Trust
CLOUDFLARE_TUNNEL_TOKEN=

# Optional direct webhook notification endpoint (for example Power Automate / Teams)
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_BEARER_TOKEN=
NOTIFICATION_BATCH_DELAY_MS=2000

# Docker Hub credentials used by the publish script
DOCKERHUB_USERNAME=sawicki
DOCKERHUB_TOKEN=

#########################################
# PORTAINER SMB STORAGE
#########################################

SMB_HOST=192.168.30.30
SMB_SHARE=uploads
SMB_USERNAME=portainer
SMB_PASSWORD=
SMB_VERS=3.0
SMB_UID=0
SMB_GID=0
SMB_FILE_MODE=0660
SMB_DIR_MODE=0770

#########################################
# IMAGE PUBLISHING
#########################################

DOCKER_IMAGE_REPO=sawicki/file-upload
DOCKER_IMAGE_TAG=latest
DOCKER_PLATFORMS=linux/amd64,linux/arm64
BUILDX_BUILDER=multiarch-builder
PUBLISH_LATEST=true

#########################################
# REVERSE PROXY
#########################################

# Required when Cloudflare Tunnel is in front of the app.
TRUST_PROXY=true

# Leave empty when trusting the immediate proxy hop.
TRUSTED_PROXY_IPS=
TRUSTED_PROXY_IP_FILES=

# Direct Cloudflare proxy only. Do not enable this when using cloudflared tunnel.
RESTRICT_TO_ALLOWED_SOURCE_IPS=false
ALLOWED_SOURCE_IPS=
ALLOWED_SOURCE_IP_FILES=
